@model MaintenanceModel
<div class="card-body">
    <div class="form-group row">
        <div class="col-md-12">
            <div>
                <p>
                    @T("Admin.System.Maintenance.ShrinkDatabase.Text")
                </p>
                <p>
                    <ul>
                        <input type="hidden" asp-for="DatabaseSize" />
                        <li>@Html.Raw(Model.DatabaseSize)</li>
                    </ul>
                </p>
            </div>
            <div>
                <button type="button" id="shrink-database" class="btn btn-default">
                    <i class="fas fa-gears"></i>
                    @T("Admin.System.Maintenance.ShrinkDatabase")
                </button>
                <script>
                    $(function() {
                        $('#shrink-database-action-confirmation-submit-button').on('click', function () {
                            $("html, body").animate({ scrollTop: 0 }, 400);
                            showThrobber('@Html.Raw(JavaScriptEncoder.Default.Encode(T("Admin.System.Maintenance.ShrinkDatabase.Progress").Text))');

                            const opener = $("#shrink-database");
                            opener.prop({
                                name: "shrink-database",
                                type: "submit"
                            });

                            opener.click();
                        });
                    });
                </script>
            </div>
        </div>
    </div>
</div>
<nop-action-confirmation asp-button-id="shrink-database" />